# VisualVault API Integration Test Configuration
# Copy this file to .env and fill in your test environment values

# =============================================================================
# REQUIRED - Core API Configuration
# =============================================================================

# OAuth Credentials
VV_CLIENT_ID=your-client-id
VV_CLIENT_SECRET=your-client-secret

# User Credentials
VV_USERNAME=your-test-username
VV_PASSWORD=your-test-password

# API Configuration
# For remote servers: https://your-instance.visualvault.com
# For local servers in devcontainer: http://host.docker.internal/VisualVault
VV_BASE_URL=https://your-instance.visualvault.com
VV_CUSTOMER_ALIAS=your-customer
VV_DATABASE_ALIAS=your-database
VV_AUDIENCE=your-audience

# =============================================================================
# Test Resource IDs
# =============================================================================

# -----------------------------------------------------------------------------
# CustomQueryManager tests
# Requires a custom query configured on the server
# -----------------------------------------------------------------------------
# VV_TEST_CUSTOM_QUERY_NAME=your-custom-query-name
# VV_TEST_CUSTOM_QUERY_ID=your-custom-query-guid

# -----------------------------------------------------------------------------
# FormsManager AND FormInstanceManager tests
# -----------------------------------------------------------------------------
# VV_TEST_FORM_TEMPLATE_REVISION_ID_FOR_CREATE=your-form-template-revision-guid

# -----------------------------------------------------------------------------
# FormsManager tests (unreleased form templates)
# Note: releaseFormTemplate is a one-way operation, use separate templates
# -----------------------------------------------------------------------------
# VV_TEST_UNRELEASED_FORM_TEMPLATE_ID_FOR_IMPORT=your-unreleased-template-guid
# VV_TEST_UNRELEASED_FORM_TEMPLATE_ID_FOR_RELEASE=your-unreleased-template-guid

# -----------------------------------------------------------------------------
# CustomerDatabaseManager tests (user assignment/removal)
# -----------------------------------------------------------------------------
# VV_TEST_CUSTOMER_DATABASE_ID=your-database-guid
# VV_TEST_CUSTOMER_DATABASE_USERNAME=username-for-assign-test
# VV_TEST_CUSTOMER_DATABASE_AUTH_USER_ID=auth-user-guid-for-remove-test

# -----------------------------------------------------------------------------
# CustomerManager tests (customer user assignment)
# Note: OPTIONAL - There is no API endpoint to undo this, enable only when needed
# -----------------------------------------------------------------------------
# VV_TEST_CUSTOMER_ID=your-customer-guid
# VV_TEST_CUSTOMER_USERNAME=username-for-customer-assign-test

# -----------------------------------------------------------------------------
# ProjectsManager tests (alert subscriptions)
# -----------------------------------------------------------------------------
# VV_TEST_PROJECT_ID=your-project-guid
# VV_TEST_PROJECT_EVENT_ID=your-project-event-guid

# -----------------------------------------------------------------------------
# ScheduledProcessManager tests (completion notification)
# -----------------------------------------------------------------------------
# VV_TEST_SCHEDULED_PROCESS_ID=your-scheduled-process-guid

# -----------------------------------------------------------------------------
# ScriptsManager tests (web services)
# -----------------------------------------------------------------------------
# VV_TEST_WEB_SERVICE_NAME=your-web-service-name

# -----------------------------------------------------------------------------
# SecurityMembersManager tests (security member operations)
# -----------------------------------------------------------------------------
# VV_TEST_SECURITY_PARENT_ID=your-security-parent-guid
# VV_TEST_SECURITY_MEMBER_ID=your-security-member-guid

# -----------------------------------------------------------------------------
# ReportsManager tests (PDF generation)
# Note: OPTIONAL - This functionality is older and may not be commonly used
# -----------------------------------------------------------------------------
# VV_TEST_REPORT_ID=your-report-guid

# -----------------------------------------------------------------------------
# LibraryManager tests (folder operations)
# -----------------------------------------------------------------------------
# VV_TEST_FOLDER_SECURITY_ID=folder-guid-for-security-tests
# VV_TEST_FOLDER_SECURITY_MEMBER_ID=group-guid-to-add-as-security-member
# VV_TEST_FOLDER_EVENT_ID=folder-event-guid-for-alert-subscription
# VV_TEST_FOLDER_ALERT_USER_ID=user-id-for-alert-subscription
# VV_TEST_FOLDER_INDEX_FIELD_ID=index-field-guid-for-override-settings

# -----------------------------------------------------------------------------
# DocumentsManager tests (index field operations)
# Requires a folder with at least one index field configured
# -----------------------------------------------------------------------------
# VV_TEST_INDEX_FOLDER_ID=folder-guid-with-index-fields

# -----------------------------------------------------------------------------
# ModelManager tests (intelligent object model operations)
# Note: OPTIONAL - These tests require a model to be set up with specific characteristics, enable only when needed
# -----------------------------------------------------------------------------
# VV_TEST_MODEL_ID=your-model-guid

# -----------------------------------------------------------------------------
# ObjectManager tests (intelligent object operations)
# Note: OPTIONAL - These tests require an object instance to be set up with specific characteristics, enable only when needed
# -----------------------------------------------------------------------------
# VV_TEST_OBJECT_MODEL_ID=your-object-model-guid
# VV_TEST_OBJECT_INSTANCE_ID=your-object-instance-guid

# -----------------------------------------------------------------------------
# UserNotificationsManager tests (user notification operations)
# -----------------------------------------------------------------------------
# VV_SKIP_USER_NOTIFICATION_TESTS=false
# VV_TEST_USER_NOTIFICATION_USER_ID=your-notify-user-guid

# -----------------------------------------------------------------------------
# WorkflowManager tests (workflow operations)
# -----------------------------------------------------------------------------
# VV_TEST_WORKFLOW_ID=your-workflow-guid
