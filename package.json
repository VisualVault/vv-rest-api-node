{
  "name": "@visualvault/vv-rest-api-node",
  "version": "2.0.0-beta.0",
  "description": "A Node.js client library for the VisualVault APIs",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./constants": {
      "import": "./dist/constants.js",
      "require": "./dist/constants.cjs"
    },
    "./VVRestApi": {
      "import": "./dist/VVRestApi.js",
      "require": "./dist/VVRestApi.cjs"
    }
  },
  "keywords": [
    "visualvault",
    "api",
    "rest",
    "client",
    "document",
    "management",
    "forms",
    "nodejs"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "debug": "^4.3.7",
    "js-yaml": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VisualVault/vv-rest-api-node.git"
  },
  "author": "VisualVault",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/VisualVault/vv-rest-api-node/issues"
  },
  "homepage": "https://github.com/VisualVault/vv-rest-api-node#readme",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.6.1",
    "dotenv": "^17.2.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
